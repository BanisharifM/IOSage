# =============================================================================
# SC 2026 Project .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Paper (separate git repo connected to Overleaf)
# -----------------------------------------------------------------------------
paper/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
eggs/
.eggs/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
.venv/

# -----------------------------------------------------------------------------
# ML / PyTorch
# -----------------------------------------------------------------------------
# Model weights (tracked via Git LFS when needed)
# *.pt  *.pth  *.ckpt  -- uncomment to ignore, or use LFS

# Weights & Biases
wandb/

# TensorBoard / logs
runs/
logs/

# MLflow
mlruns/

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# LaTeX build artifacts
# -----------------------------------------------------------------------------
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb
*.bcf
*.run.xml
*.xdv
paper/*.log
paper/*.out

# Compiled PDF (regenerable; Overleaf compiles its own)
paper/main.pdf

# -----------------------------------------------------------------------------
# Data Files
# -----------------------------------------------------------------------------
# Raw Darshan logs (1.37M files - too large for git)
Darshan_Logs/2024/
Darshan_Logs/2025/
Darshan_Logs/2026/
Darshan_Logs/.last_collection
Darshan_Logs/.meta/

# Darshan log files anywhere
*.darshan

# Intermediate extraction chunks (regenerable from raw logs)
data/processed/archive/

# Benchmark logs (generated locally)
data/benchmark_logs/

# NOTE: Parquet files (data/processed/*.parquet, data/processed/splits/*.parquet)
# are tracked via Git LFS -- do NOT ignore them here.

# -----------------------------------------------------------------------------
# Results & Outputs
# -----------------------------------------------------------------------------
results/*.json
results/*.csv
results/ablation/
!results/expected/

# -----------------------------------------------------------------------------
